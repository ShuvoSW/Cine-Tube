
model Media {
  id            String @id @default(uuid())
  type          MediaType
  title         String
  coverImage    String
  synopsis      String
  genre         Genre[]
  releaseYear   Int
  director      String
  cast          String[]
  platform      String
  priceType     PriceType
  youtubeLink   String
  
  review        Review[]
  watchlist     Watchlist[]

  averageRating Float   @default(0)
  totalReviews   Int     @default(0)

  createdAt     DateTime @default(now())

  @@map("media")
}